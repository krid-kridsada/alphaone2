# JSON string ของ Firebase config (คัดลอกจาก Firebase Console → Project settings)
# ตัวอย่าง: {"apiKey":"...","authDomain":"...","projectId":"..."}
VITE_FIREBASE_CONFIG=

# ไอดีแอป/โปรเจกต์ (ใช้กับ path Firestore เดิม)
VITE_APP_ID=default-app-id

# ไม่บังคับ: custom token สำหรับ sign-in (ถ้าไม่ใส่จะใช้ anonymous auth)
# VITE_INITIAL_AUTH_TOKEN=
